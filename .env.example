# =============================================================================
# Distillery — environment configuration template
# -----------------------------------------------------------------------------
# Copy to `.env` and adjust. Every variable is prefixed with DISTILLERY_ and is
# parsed by `distillery.config.settings.Settings` (pydantic-settings).
# Nested settings use a double underscore delimiter, e.g.
#   DISTILLERY_DATABASE__URL=...
# Twelve-Factor App: configuration lives strictly in the environment.
# =============================================================================

# ---- Core ------------------------------------------------------------------
DISTILLERY_ENV=development                 # development | staging | production
DISTILLERY_DEBUG=true
DISTILLERY_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
DISTILLERY_LOG_FORMAT=json                  # json | console
DISTILLERY_SERVICE_NAME=distillery-api

# ---- API server ------------------------------------------------------------
DISTILLERY_API__HOST=0.0.0.0
DISTILLERY_API__PORT=8000
DISTILLERY_API__ROOT_PATH=
DISTILLERY_API__CORS_ORIGINS=["http://localhost:3000"]
DISTILLERY_API__DOCS_ENABLED=true

# ---- Security --------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DISTILLERY_SECURITY__JWT_SECRET=change-me-in-production-use-a-64-char-random-string
DISTILLERY_SECURITY__JWT_ALGORITHM=HS256
DISTILLERY_SECURITY__ACCESS_TOKEN_TTL_SECONDS=3600
DISTILLERY_SECURITY__API_KEY_HEADER=X-API-Key
# Comma-separated bootstrap admin API keys (hashed at startup). Empty in prod.
DISTILLERY_SECURITY__BOOTSTRAP_API_KEYS=dev-local-admin-key
DISTILLERY_SECURITY__RATE_LIMIT_PER_MINUTE=120

# ---- Database (PostgreSQL) -------------------------------------------------
DISTILLERY_DATABASE__URL=postgresql+psycopg://distillery:distillery@localhost:5432/distillery
DISTILLERY_DATABASE__POOL_SIZE=10
DISTILLERY_DATABASE__MAX_OVERFLOW=20
DISTILLERY_DATABASE__POOL_TIMEOUT_SECONDS=30
DISTILLERY_DATABASE__ECHO=false

# ---- Queue / broker (Redis + Celery) --------------------------------------
DISTILLERY_QUEUE__BROKER_URL=redis://localhost:6379/0
DISTILLERY_QUEUE__RESULT_BACKEND=redis://localhost:6379/1
DISTILLERY_QUEUE__TASK_TIME_LIMIT_SECONDS=86400
DISTILLERY_QUEUE__WORKER_CONCURRENCY=2

# ---- Object storage --------------------------------------------------------
DISTILLERY_STORAGE__BACKEND=local           # local | s3
DISTILLERY_STORAGE__LOCAL_ROOT=./artifacts
DISTILLERY_STORAGE__S3_BUCKET=
DISTILLERY_STORAGE__S3_ENDPOINT_URL=
DISTILLERY_STORAGE__S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY read from standard AWS env vars.

# ---- LLM teacher (Anthropic) ----------------------------------------------
DISTILLERY_LLM__PROVIDER=anthropic
DISTILLERY_LLM__ANTHROPIC_API_KEY=
DISTILLERY_LLM__DEFAULT_TEACHER_MODEL=claude-sonnet-4-6
DISTILLERY_LLM__MAX_CONCURRENCY=4
DISTILLERY_LLM__REQUEST_TIMEOUT_SECONDS=120
DISTILLERY_LLM__MAX_RETRIES=5

# ---- Training defaults -----------------------------------------------------
DISTILLERY_TRAINING__DEVICE=auto            # auto | cpu | cuda | mps
DISTILLERY_TRAINING__DEFAULT_SEED=42
DISTILLERY_TRAINING__MAX_EPOCHS=3
DISTILLERY_TRAINING__MIXED_PRECISION=false

# ---- Observability ---------------------------------------------------------
DISTILLERY_OBSERVABILITY__METRICS_ENABLED=true
DISTILLERY_OBSERVABILITY__METRICS_PORT=9100
DISTILLERY_OBSERVABILITY__TRACING_ENABLED=false
DISTILLERY_OBSERVABILITY__OTLP_ENDPOINT=
